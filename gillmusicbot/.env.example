# Copy this file to ".env" for LOCAL testing only.
# NEVER commit your real .env to GitHub — it contains secret tokens.

# ── Required ─────────────────────────────────────────────────────────────────
# Get these from https://discord.com/developers/applications → Your App
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# ── Recommended (fixes YouTube rate-limiting on cloud hosts) ─────────────────
# 1. Install the "Get cookies.txt LOCALLY" extension in Chrome/Edge
# 2. Go to youtube.com while logged in, click the extension, export cookies
# 3. Paste the ENTIRE contents of the downloaded file as the value below
# YOUTUBE_COOKIES_TXT=<paste full Netscape cookie file here>

# ── Optional ─────────────────────────────────────────────────────────────────
# YTDLP_PATH=/usr/bin/yt-dlp     # override yt-dlp binary path
# FFMPEG_PATH=/usr/bin/ffmpeg    # override ffmpeg binary path
# YTDLP_SKIP_UPDATE=true         # skip auto-update of yt-dlp on startup
